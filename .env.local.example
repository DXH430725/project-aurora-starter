# Password gate for local development.
AUTH_PASSWORD=changeme
AUTH_SECRET=your-secret-min-32-chars-change-this-now

# Production uses the Prometheus instance colocated with the app, for example:
# PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_URL=

# Local monitor/status UI development. Set to 1 to use deterministic mock data.
# Production should leave this empty or set it to 0.
MONITOR_MOCK=1

# Main app summary BFF targets. Production should use loopback service URLs.
INTERNAL_STATUS_URL=http://localhost:3002
INTERNAL_AMP_URL=http://localhost:3003

# Main app rewrite targets. Production defaults to public child-zone domains.
STATUS_ZONE_URL=http://localhost:3002
AMP_ZONE_URL=http://localhost:3003
