# Password gate for local development.
AUTH_PASSWORD=changeme
AUTH_SECRET=your-secret-min-32-chars-change-this-now

# Optional legacy WebSocket demo server.
NEXT_PUBLIC_WS_URL=ws://localhost:8787
ENABLE_INSPECTOR=true

# Production uses the Prometheus instance colocated with the app, for example:
# PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_URL=

# Local monitor/status UI development. Set to 1 to use deterministic mock data.
# Production should leave this empty or set it to 0.
MONITOR_MOCK=1
